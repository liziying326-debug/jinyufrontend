.pd-rel-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,.1); transform: translateY(-3px); }
.pd-rel-card img { width: 100%; aspect-ratio: 4/3; object-fit: cover; }
.pd-rel-card-name { padding: 12px 14px; font-size: 13px; font-weight: 600; color: #333; }

/* Not found state */
