.pd-spec-table tr:last-child { border-bottom: none; }
.pd-spec-table td { padding: 10px 8px; font-size: 14px; }
.pd-spec-table td:first-child { color: #888; width: 45%; }
.pd-spec-table td:last-child { color: #222; font-weight: 500; }

.pd-features { margin-bottom: 28px; }
.pd-features h4 { font-size: 14px; font-weight: 700; color: #333; margin-bottom: 12px; text-transform: uppercase; letter-spacing: .05em; }
.pd-feature-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
.pd-feature-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #444; }
.pd-feature-list li::before { content: "✓"; color: #e87722; font-weight: 700; flex-shrink: 0; margin-top: 1px; }

.pd-actions { display: flex; gap: 12px; flex-wrap: wrap; }
.pd-btn-quote { display: inline-flex; align-items: center; gap: 8px; background: #e87722; color: #fff;
               padding: 14px 32px; border-radius: 8px; font-size: 15px; font-weight: 600;
               text-decoration: none; transition: background .2s; }
.pd-btn-quote:hover { background: #d4621a; }
.pd-btn-back { display: inline-flex; align-items: center; gap: 8px; background: #fff; color: #333;
               padding: 14px 24px; border-radius: 8px; font-size: 15px; font-weight: 500;
               text-decoration: none; border: 2px solid #ddd; transition: border-color .2s; }
.pd-btn-back:hover { border-color: #e87722; color: #e87722; }

/* Related Products */
.pd-related { padding: 60px 0; border-top: 1px solid #eee; }
.pd-related h3 { font-size: 22px; font-weight: 700; margin-bottom: 28px; color: #1a1a2e; }
.pd-related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; }
.pd-rel-card { border-radius: 10px; overflow: hidden; border: 1px solid #eee; cursor: pointer;
