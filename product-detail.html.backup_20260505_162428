.pd-specs { background: #f9f9fb; border-radius: 12px; padding: 24px; margin-bottom: 28px; }
.pd-specs h4 { font-size: 14px; font-weight: 700; color: #333; margin-bottom: 16px; text-transform: uppercase; letter-spacing: .05em; }
.pd-spec-table { width: 100%; border-collapse: collapse; }
