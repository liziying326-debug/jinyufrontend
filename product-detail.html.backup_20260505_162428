<script>
// 产品详情页 - API 驱动

function getProductImage(p) {
  if (p.images && p.images.length > 0) return p.images[0];
  if (p.img) return p.img;
  return '';
}

async function loadProductDetail() {
  const pathParts = window.location.pathname.replace(/^\/|\/$/g, '').split('/');
  let slug = '';
  if (pathParts.length >= 2 && pathParts[0] === 'products') {
    slug = decodeURIComponent(pathParts[1]);
  }
  if (!slug) {
    const params = new URLSearchParams(window.location.search);
    slug = params.get('slug') || params.get('id') || '';
  }
  if (!slug) {
    document.getElementById('pdNotFound').style.display = 'block';
    return;
  }

  try {
    const res = await fetch('/api/products');
    const apiResponse = await res.json();
    const products = apiResponse.data || apiResponse;
    const product = products.find(p => p.id === slug);
    
    if (!product) {
      document.getElementById('pdNotFound').style.display = 'block';
      return;
    }
    
    renderProduct(product, products);
  } catch(e) {
    console.error('[ProductDetail] load failed:', e);
    document.getElementById('pdNotFound').style.display = 'block';
  }
}

function renderProduct(p, allProducts) {
  var lang = (document.documentElement.lang || 'en').toLowerCase();
  var name = (p.name_en || p.name || '');
  var desc = (p.description_en || p.description || '');
  var img = getProductImage(p);
  var imgs = p.images || (p.img ? [p.img] : []);
  
  document.title = name + ' – Jinyu';
  var bannerName = document.getElementById('pdBannerName');
  if (bannerName) bannerName.textContent = name;
  
  var body = document.getElementById('pdBody');
  if (body) body.style.display = 'block';
  
  var mainImg = document.getElementById('pdMainImg');
  if (mainImg) { mainImg.src = img; mainImg.alt = name; }
  
  var thumbsDiv = document.getElementById('pdThumbs');
  if (thumbsDiv) {
    thumbsDiv.innerHTML = imgs.map(function(src, i) {
      return '<img src="' + src + '" class="pd-thumb' + (i === 0 ? ' active' : '') + '" onclick="window.switchMainImg(this)" alt="thumb">';
    }).join('');
  }
  
  var catEl = document.getElementById('pdCategory');
  if (catEl) catEl.textContent = p.category_id || '';
  
  var nameEl = document.getElementById('pdName');
  if (nameEl) nameEl.textContent = name;
  
  var descEl = document.getElementById('pdDesc');
  if (descEl) descEl.textContent = desc;
  
  var specTable = document.getElementById('pdSpecTable');
  if (specTable && p.specs) {
    specTable.innerHTML = p.specs.map(function(s) {
      return '<tr><td>' + (s.k_en || '') + '</td><td>' + (s.v_en || '') + '</td></tr>';
    }).join('');
  }
  
  var featList = document.getElementById('pdFeatureList');
  if (featList) {
    var features = [];
    try {
      if (typeof p.features_en === 'string') features = JSON.parse(p.features_en);
      else if (Array.isArray(p.features_en)) features = p.features_en;
      else if (Array.isArray(p.features)) features = p.features;
    } catch(e) {}
    featList.innerHTML = features.map(function(f) { return '<li>' + f + '</li>'; }).join('');
  }
}

window.switchMainImg = function(thumb) {
  var mainImg = document.getElementById('pdMainImg');
  if (mainImg) mainImg.src = thumb.src;
  document.querySelectorAll('.pd-thumb').forEach(function(t) { t.classList.remove('active'); });
  thumb.classList.add('active');
};

document.addEventListener('DOMContentLoaded', loadProductDetail);
</script>
